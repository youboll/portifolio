---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const isProd = import.meta.env.PROD;
const posts = (await getCollection("blog", ({ data }) => (isProd ? !data.draft : true)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const dateFmt = new Intl.DateTimeFormat("en-US", { month: "short", day: "2-digit", year: "numeric" });

const work = [
  {
    href: "/work/#agent-swarm",
    year: "2026",
    title: "Mindz · Agent swarm refactor",
    featured: true,
    stack: "Django · Vue · Claude Code · 40 agents",
    blurb: "<b>40 agents · 150 pages · 6 days · production.</b> Orchestrated ten lead agents with four sub-agents each to migrate the Fomantic UI templates to Vuexy components — a backlog the team had been postponing for years.",
  },
  {
    href: "/work/#abac",
    year: "2024",
    title: "Mindz · ABAC authorization layer",
    stack: "Django · MySQL · OAuth2 PKCE",
    blurb: "Replaced the role table with attribute-based access control across the platform. Trade-offs documented inside.",
  },
  {
    href: "/work/#multi-db-router",
    year: "2023",
    title: "Multi-DB router for tenant isolation",
    stack: "Django · MySQL · Redis",
    blurb: "Database-per-tenant routing with single sign-on across platforms — log in once, switch context without re-auth.",
  },
  {
    href: "/work/#oauth2-server",
    year: "2022",
    title: "Server-side OAuth2 issuer",
    stack: "Django · OAuth2 · iframe SSO",
    blurb: "Custom OAuth2 server for white-labeled course player embeds, with rotating client credentials and full token audit.",
  },
];
---
<Layout current="home">
  <section class="hero" style="margin-top: 0;">
    <h1>Pedro Mansan</h1>
    <div class="role">Full stack engineer · Brazil</div>

    <p class="lede">
      I'm a full stack developer working on multi-tenant SaaS — mostly Python/Django on the
      backend, Vue on the frontend, AWS in between. I like systems with hard edges: auth,
      multi-tenancy, performance under real load.
    </p>

    <p>
      Most recently at <a href="/work/">Mindz (2022–2026)</a>, where I led the migration of a
      150-page legacy course platform with a swarm of 40 Claude Code agents in a week.
      Currently studying CS at UTFPR.
    </p>

    <p class="meta-line">
      Available for remote roles with US/EU teams. Write to
      <a href="mailto:pedro.ciclobrasil@gmail.com">pedro.ciclobrasil@gmail.com</a>.
    </p>

    <div class="status" style="margin-top: 20px;">
      <span class="dot"></span>
      <span>Available since April 2026</span>
    </div>
  </section>

  <section id="work">
    <h2>Selected work</h2>
    <div class="work">
      {work.map((item) => (
        <a class="work-item" href={item.href}>
          <span class="year mono">{item.year}</span>
          <div class="body">
            <div class="work-title">
              {item.title}
              {item.featured && <span class="featured-tag">case study</span>}
            </div>
            <div class="work-stack">{item.stack}</div>
            <div class="work-blurb" set:html={item.blurb} />
          </div>
          <span class="arrow">↗</span>
        </a>
      ))}
    </div>
  </section>

  <section id="writing">
    <h2>Writing</h2>
    <div class="work">
      {posts.map((post) => (
        <a class="writing-item" href={`/writing/${post.id}/`}>
          <span class="date mono">{dateFmt.format(post.data.pubDate)}</span>
          <div class="body">
            <div class="writing-title">
              {post.data.title}
              {post.data.draft && <span class="draft-tag">draft</span>}
            </div>
            <div class="writing-meta">
              {post.data.readingTime ?? "—"}{post.data.tag ? ` · ${post.data.tag}` : ""}
            </div>
          </div>
          <span class="arrow">↗</span>
        </a>
      ))}
    </div>
    <p style="margin-top: 16px; font-size: 13px; color: var(--fg-2);">
      <a href="/writing/">All writing →</a>
    </p>
  </section>
</Layout>
