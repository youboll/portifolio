---
import Layout from "../../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { getLocale, t, dateLocale, localizePath } from "../../../i18n/ui";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ id }) => id.startsWith("pt-br/"));
  return posts.map((post) => ({
    params: { slug: post.id.slice("pt-br/".length) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const locale = getLocale(Astro.currentLocale);
const dateFmt = new Intl.DateTimeFormat(dateLocale(locale), { month: "short", day: "2-digit", year: "numeric" });
const writingHref = localizePath("/writing/", locale);
---
<Layout
  title={`${post.data.title} — Pedro Mansan`}
  description={post.data.description}
  current="writing"
>
  <article class="prose" style="margin-top: 8px;">
    <p style="margin-bottom: 24px;">
      <a href={writingHref} style="font-family: var(--font-mono); font-size: 12px; color: var(--fg-2); text-decoration: none;">{t(locale, "writing.back")}</a>
    </p>

    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <span>{dateFmt.format(post.data.pubDate)}</span>
      {post.data.readingTime && <span>· {post.data.readingTime}</span>}
      {post.data.tag && <span>· {post.data.tag}</span>}
      {post.data.draft && <span class="draft-tag">{t(locale, "writing.draft")}</span>}
    </div>

    <Content />
  </article>
</Layout>
